{
  "$defs": {
    "Dimensions": {
      "additionalProperties": false,
      "properties": {
        "width": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Width"
        },
        "depth": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Depth"
        },
        "height": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Height"
        },
        "radius": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Radius"
        }
      },
      "title": "Dimensions",
      "type": "object"
    },
    "GroupObject": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Id",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Label",
          "type": "string"
        },
        "position": {
          "$ref": "#/$defs/Vector3"
        },
        "rotation": {
          "$ref": "#/$defs/Rotation"
        },
        "material": {
          "$ref": "#/$defs/Material"
        },
        "visible": {
          "default": true,
          "title": "Visible",
          "type": "boolean"
        },
        "type": {
          "const": "group",
          "default": "group",
          "title": "Type",
          "type": "string"
        },
        "children": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Children",
          "type": "array"
        }
      },
      "required": [
        "id",
        "label",
        "children"
      ],
      "title": "GroupObject",
      "type": "object"
    },
    "Material": {
      "additionalProperties": false,
      "properties": {
        "color": {
          "default": "#B8B8B8",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "title": "Color",
          "type": "string"
        },
        "metallic": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Metallic",
          "type": "number"
        },
        "roughness": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Roughness",
          "type": "number"
        }
      },
      "title": "Material",
      "type": "object"
    },
    "OperationObject": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Id",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Label",
          "type": "string"
        },
        "position": {
          "$ref": "#/$defs/Vector3"
        },
        "rotation": {
          "$ref": "#/$defs/Rotation"
        },
        "material": {
          "$ref": "#/$defs/Material"
        },
        "visible": {
          "default": true,
          "title": "Visible",
          "type": "boolean"
        },
        "type": {
          "const": "operation",
          "default": "operation",
          "title": "Type",
          "type": "string"
        },
        "operation": {
          "enum": [
            "union",
            "difference",
            "intersection"
          ],
          "title": "Operation",
          "type": "string"
        },
        "children": {
          "items": {
            "type": "string"
          },
          "minItems": 2,
          "title": "Children",
          "type": "array"
        }
      },
      "required": [
        "id",
        "label",
        "operation",
        "children"
      ],
      "title": "OperationObject",
      "type": "object"
    },
    "PrimitiveObject": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Id",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Label",
          "type": "string"
        },
        "position": {
          "$ref": "#/$defs/Vector3"
        },
        "rotation": {
          "$ref": "#/$defs/Rotation"
        },
        "material": {
          "$ref": "#/$defs/Material"
        },
        "visible": {
          "default": true,
          "title": "Visible",
          "type": "boolean"
        },
        "type": {
          "const": "primitive",
          "default": "primitive",
          "title": "Type",
          "type": "string"
        },
        "shape": {
          "enum": [
            "box",
            "cylinder",
            "sphere",
            "cone",
            "prism"
          ],
          "title": "Shape",
          "type": "string"
        },
        "dimensions": {
          "$ref": "#/$defs/Dimensions"
        }
      },
      "required": [
        "id",
        "label",
        "shape",
        "dimensions"
      ],
      "title": "PrimitiveObject",
      "type": "object"
    },
    "Rotation": {
      "additionalProperties": false,
      "properties": {
        "x": {
          "default": 0.0,
          "title": "X",
          "type": "number"
        },
        "y": {
          "default": 0.0,
          "title": "Y",
          "type": "number"
        },
        "z": {
          "default": 0.0,
          "title": "Z",
          "type": "number"
        }
      },
      "title": "Rotation",
      "type": "object"
    },
    "Scene": {
      "additionalProperties": false,
      "properties": {
        "objects": {
          "items": {
            "discriminator": {
              "mapping": {
                "group": "#/$defs/GroupObject",
                "operation": "#/$defs/OperationObject",
                "primitive": "#/$defs/PrimitiveObject"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/PrimitiveObject"
              },
              {
                "$ref": "#/$defs/OperationObject"
              },
              {
                "$ref": "#/$defs/GroupObject"
              }
            ]
          },
          "title": "Objects",
          "type": "array"
        }
      },
      "title": "Scene",
      "type": "object"
    },
    "Vector3": {
      "additionalProperties": false,
      "properties": {
        "x": {
          "default": 0.0,
          "title": "X",
          "type": "number"
        },
        "y": {
          "default": 0.0,
          "title": "Y",
          "type": "number"
        },
        "z": {
          "default": 0.0,
          "title": "Z",
          "type": "number"
        }
      },
      "title": "Vector3",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Version",
      "type": "string"
    },
    "intent": {
      "minLength": 1,
      "title": "Intent",
      "type": "string"
    },
    "history": {
      "items": {
        "type": "string"
      },
      "title": "History",
      "type": "array"
    },
    "units": {
      "const": "meters",
      "default": "meters",
      "title": "Units",
      "type": "string"
    },
    "scene": {
      "$ref": "#/$defs/Scene"
    }
  },
  "required": [
    "intent"
  ],
  "title": "EngineeringIR",
  "type": "object"
}
